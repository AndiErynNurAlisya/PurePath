<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PurePath"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp"/>

        </LinearLayout>

        <!-- Profil Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/PurePath.Card"
            android:layout_marginBottom="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="👤"
                    android:textSize="24sp"
                    android:background="@color/ice"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Pengguna"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_user_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="email@purepath.ai"
                        android:textSize="13sp"
                        android:textColor="?attr/colorSecondary"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_explore"
                    app:tint="?attr/colorSecondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Health Profile Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HEALTH PROFILE"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorSecondary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/PurePath.Card"
            android:layout_marginBottom="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pilih kondisi kesehatan kamu agar rekomendasi lebih personal:"
                    android:textSize="12sp"
                    android:textColor="?attr/colorSecondary"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp"/>

                <CheckBox
                    android:id="@+id/cb_asma"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Asma"
                    android:padding="8dp"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary"/>

                <CheckBox
                    android:id="@+id/cb_ispa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ISPA (Infeksi Saluran Pernapasan)"
                    android:padding="8dp"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary"/>

                <CheckBox
                    android:id="@+id/cb_lupus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lupus (LES)"
                    android:padding="8dp"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary"/>

                <CheckBox
                    android:id="@+id/cb_eksim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Eksim (Dermatitis Atopik)"
                    android:padding="8dp"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary"/>

                <CheckBox
                    android:id="@+id/cb_rosacea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rosacea"
                    android:padding="8dp"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary"/>

                <CheckBox
                    android:id="@+id/cb_herpes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Herpes Labialis"
                    android:padding="8dp"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- App Preferences -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APP PREFERENCES"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorSecondary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/PurePath.Card"
            android:layout_marginBottom="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Theme -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌙 Tema Gelap"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_dark_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:backgroundTint="@color/aqi_unhealthy"
            style="@style/PurePath.Button"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Version 1.0.0 (2026)"
            android:textSize="12sp"
            android:textColor="?attr/colorSecondary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
