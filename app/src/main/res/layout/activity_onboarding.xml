<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PurePath"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profil Kesehatan"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bantu kami menyesuaikan peringatan untuk kondisi fisik Anda."
        android:textSize="14sp"
        android:textColor="?attr/colorSecondary"
        android:layout_marginBottom="24dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Asma -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_asma"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PurePath.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_asma"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:background="@color/ice"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Asma"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sensitif terhadap partikel udara"
                            android:textSize="12sp"
                            android:textColor="?attr/colorSecondary"/>

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cb_asma"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ocean"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ISPA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ispa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PurePath.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_ispa"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:background="@color/ice"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ISPA"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Infeksi Saluran Pernapasan Akut"
                            android:textSize="12sp"
                            android:textColor="?attr/colorSecondary"/>

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cb_ispa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ocean"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Lupus -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_lupus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PurePath.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_lupus"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:background="@color/ice"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lupus (LES)"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sensitif terhadap paparan UV"
                            android:textSize="12sp"
                            android:textColor="?attr/colorSecondary"/>

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cb_lupus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ocean"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Eksim -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_eksim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PurePath.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_eksim"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:background="@color/ice"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Eksim (Dermatitis)"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sensitif terhadap polusi dan UV"
                            android:textSize="12sp"
                            android:textColor="?attr/colorSecondary"/>

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cb_eksim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ocean"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rosacea -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_rosacea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PurePath.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_rosacea"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:background="@color/ice"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rosacea"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kulit sensitif terhadap UV"
                            android:textSize="12sp"
                            android:textColor="?attr/colorSecondary"/>

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cb_rosacea"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ocean"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Herpes -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_herpes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PurePath.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_herpes"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:background="@color/ice"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Herpes Labialis"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dipicu oleh paparan UV berlebih"
                            android:textSize="12sp"
                            android:textColor="?attr/colorSecondary"/>

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cb_herpes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ocean"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tidak Ada -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PurePath.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_sehat"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:background="@color/ice"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tidak Ada Kondisi Khusus"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tanpa kondisi spesifik"
                            android:textSize="12sp"
                            android:textColor="?attr/colorSecondary"/>

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cb_none"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ocean"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_lanjut"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lanjut"
        style="@style/PurePath.Button"
        android:layout_marginTop="16dp"/>

</LinearLayout>