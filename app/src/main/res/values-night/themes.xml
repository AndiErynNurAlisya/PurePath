<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PurePath" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Warna utama -->
        <item name="colorPrimary">@color/cyan</item>
        <item name="colorPrimaryVariant">@color/ocean</item>
        <item name="colorOnPrimary">@color/navy</item>

        <!-- Warna sekunder -->
        <item name="colorSecondary">@color/sky</item>
        <item name="colorSecondaryVariant">@color/ice</item>
        <item name="colorOnSecondary">@color/navy</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Typography -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Style untuk TextInputLayout Dark -->
    <style name="PurePath.TextInputLayout"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/cyan</item>
        <item name="hintTextColor">@color/cyan</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Style untuk Button Dark -->
    <style name="PurePath.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/cyan</item>
        <item name="android:textColor">@color/navy</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Style untuk Card Dark -->
    <style name="PurePath.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/surface_dark</item>
    </style>

    <!-- Style untuk Bottom Navigation Dark -->
    <style name="PurePath.BottomNav"
        parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bottom_nav_dark</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
    </style>
</resources>